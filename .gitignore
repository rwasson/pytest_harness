# .gitignore

# --- private working folders ---
deprecated/
docs/todo/

# --- virtual environments ---
.venv/
venv/
env/

# --- Python cache ---
__pycache__/
*.py[cod]

# --- PyCharm ---
.idea/
*.iml

# --- logs and generated artifacts ---
logs/
**/logs/

# --- build artifacts ---
build/
dist/
*.egg-info/

# --- macOS ---
.DS_Store

# --- pytest ---
.pytest_cache/

# --- mypy ---
.mypy_cache/

# --- Ruff ---
.ruff_cache/

# --- coverage ---
.coverage
.coverage.*
coverage.json
htmlcov/

# --- Jupyter ---
.ipynb_checkpoints/